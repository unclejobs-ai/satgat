    "단청",
    "명조",
    "claude",
    "nextjs",
    "skill"
  ],
  "author": "unclejobs-ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unclejobs-ai/satgat.git"
  },
  "homepage": "https://satgat.vercel.app",
  "bugs": {
    "url": "https://github.com/unclejobs-ai/satgat/issues"
  },
  "bin": {
